{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(cp *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(echo *)",
      "Bash(eslint *)",
      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(git log *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jest *)",
      "Bash(jq *)",
      "Bash(ls*)",
      "Bash(less *)",
      "Bash(make *)",
      "Bash(mkdir *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npx tsc --version *)",
      "Bash(pip *)",
      "Bash(pnpm *)",
      "Bash(pwd)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(rg *)",
      "Bash(rgrep *)",
      "Bash(run_silent *)",
      "Bash(sed *)",
      "Bash(shellcheck *)",
      "Bash(sort *)",
      "Bash(source .venv/bin/activate)",
      "Bash(source venv/bin/activate)",
      "Bash(sqlite *)",
      "Bash(sqlite3 *)",
      "Bash(sleep *)",
      "Bash(tail *)",
      "Bash(timeout *)",
      "Bash(touch *)",
      "Bash(tr *)",
      "Bash(tree *)",
      "Bash(tsc *)",
      "Bash(type *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs *)",
      "Read(~/.claude)",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write(~/.claude/agents/**)",
      "Read(~/.claude/commands/**)",
      "Read(~/.claude/hooks/**)",
      "Write(~/.claude/skills/**)",
      "Edit(~/.claude/skills/**)",
      "Edit(~/.claude/agents/**)"
    ],
    "deny": [
      "Bash(/usr/bin/sudo *)",
      "Bash(1password *)",
      "Bash(1Password *)",
      "Bash(1pw *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl exec *)",
      "Bash(nc -l *)",
      "Bash(ncat -l *)",
      "Bash(netcat -l *)",
      "Bash(reboot *)",
      "Bash(rm -f -r .. *)",
      "Bash(rm -f -r ~)",
      "Bash(rm -f -r ~*)",
      "Bash(rm -f -r $HOME*)",
      "Bash(rm -fr .. *)",
      "Bash(rm -fr ~)",
      "Bash(rm -fr ~*)",
      "Bash(rm -fr $HOME*)",
      "Bash(rm -r -f .. *)",
      "Bash(rm -r -f ~)",
      "Bash(rm -r -f ~*)",
      "Bash(rm -r -f $HOME*)",
      "Bash(rm -rf .. *)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(shutdown *)",
      "Bash(su *)",
      "Bash(sudo *)",
      "Read(.vscode/**)",
      "Read(**/.secrets/**)",
      "Read(**/*.keychain)",
      "Read(**/1password/**)",
      "Read(**/1Password/**)",
      "Read(**/passwords/**)",
      "Read(**/Passwords/**)",
      "Read(**/secrets/**)",
      "Read(**/wallet/**)",
      "Read(**/Wallet/**)",
      "Read(//Library/Keychains/**)",
      "Read(//Library/OpenDirectory/**)",
      "Read(//Library/Security/**)",
      "Read(//var/db/**)",
      "Read(~/.ssh/**)",
      "Read(~/Library/Application Support/1Password/**)",
      "Read(~/Library/Keychains/**)",
      "Read(*.env)",
      "Bash(curl:*)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git add:*)",
      "Bash(gh pr create:*)",
      "Bash(git commit:*)",
      "Bash(rm:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "mcp-server-dev@claude-plugins-official": true,
    "claude-api@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "editorMode": "vim"
}
